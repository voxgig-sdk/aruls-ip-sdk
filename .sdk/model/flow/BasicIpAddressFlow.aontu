# BasicIpAddressFlow

main: kit: flow: BasicIpAddressFlow:
{
  entity: "ip_address",
  kind: "basic",
  name: "BasicIpAddressFlow",
  step: [
    {
      input: {
        ref: "ip_address_ref01",
        srcdatavar: "ip_address_ref01_data",
        suffix: "_dt0"
      }

      op: "load",
      valid: [
        {
          apply: "TextFieldMark",
          def: {
            mark: "Mark01-ip_address_ref01"
          }
        }
      ]
    }
  ],
  "key$": "BasicIpAddressFlow"
}